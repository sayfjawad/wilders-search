# Copy to hosts.env and fill in your own hosts (hosts.env is gitignored).
# dg_distributed.sh runs N download shards: LOCAL_SHARDS on this machine,
# the rest on remote hosts reachable over passwordless ssh with ffmpeg +
# python3 installed. Optional pull-bwlimit (rsync --bwlimit format) caps the
# rate at which dg_pull.sh drains that host's finished files.
N=4
LOCAL_SHARDS="0 1"
# host:shard:remote-workdir[:pull-bwlimit]
REMOTES="
user@host-a:2:/home/user/wilders_dg
user@host-b:3:/data/wilders_dg:12m
"
